{
  "name": "auto-knowledge-base",
  "version": "0.1.0",
  "description": "MCP-based autonomous knowledge base for engineering agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "auto-knowledge-base": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp src/storage/schema.sql dist/storage/schema.sql",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "setup": "node dist/install.js",
    "teardown": "node dist/uninstall.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
