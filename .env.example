# LLM 配置（Chat 功能：提取、重排、综合说明）
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=gpt-4o

# Embedding 配置（可选，向量搜索用）
# 不设则默认同 LLM 配置。独立配置可让 chat 和 embedding 走不同供应商。
# EMBEDDING_BASE_URL=https://api.deepseek.com
# EMBEDDING_API_KEY=sk-your-deepseek-key
# EMBEDDING_MODEL=deepseek-embedding

# 知识库路径（默认 ./knowledge）
# KNOWLEDGE_DIR=./knowledge
